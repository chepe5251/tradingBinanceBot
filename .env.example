# ──────────────────────────────────────────────────────────────────────────────
# Binance Futures Scalping Bot — Environment Configuration Template
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Binance API ───────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Use testnet endpoints for order execution (recommended for initial setup)
# Set to false ONLY when you are ready to trade with real capital
BINANCE_TESTNET=true

# Use testnet for WebSocket market data (usually false even in testnet mode)
BINANCE_DATA_TESTNET=false

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Paper Trading ─────────────────────────────────────────────────────────────
# Set to true to simulate trades without touching the exchange
USE_PAPER_TRADING=false
PAPER_START_BALANCE=25

# ── Capital & Risk ────────────────────────────────────────────────────────────
# Fixed USDT margin per trade entry
FIXED_MARGIN_PER_TRADE_USDT=5

# Maximum daily loss in USDT before the bot pauses for the day
DAILY_DRAWDOWN_LIMIT_USDT=6

# Fraction of available balance to use as the margin budget (0.50 – 0.95)
MARGIN_UTILIZATION=0.95

# ── Loss-Based Scaling (set to 0 to disable all levels) ──────────────────────
# Scaling is disabled by default until the strategy is validated in live trading.
# Level 1: triggered at -50% of initial margin
SCALE_LEVEL1_MARGIN_USDT=0
# Level 2: triggered at -100% of initial margin
SCALE_LEVEL2_MARGIN_USDT=0

# ── Risk Controls ─────────────────────────────────────────────────────────────
# Consecutive losses before pausing (default: 3)
MAX_CONSECUTIVE_LOSSES=3
# Pause duration in seconds after hitting the consecutive-loss limit (default: 86400 = end of UTC day)
RISK_PAUSE_AFTER_LOSSES_SEC=86400

# ── Symbol Universe (leave blank to use all 529+ USDT-M perpetuals) ───────────
# Comma-separated list to restrict to specific symbols
SYMBOLS=
# Additional symbols merged on top of the auto-loaded list
EXTRA_SYMBOLS=

# ── Advanced (optional overrides) ─────────────────────────────────────────────
# Risk fraction per trade (0.01 – 0.20)
RISK_PER_TRADE_PCT=0.10
# Anti-liquidation trigger multiplier in R units
ANTI_LIQ_TRIGGER_R=1.1
# Enable verbose candle update logging
LOG_CANDLE_UPDATES=false
