# Binance credentials
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_DATA_TESTNET=false

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Paper/live mode
USE_PAPER_TRADING=false
PAPER_START_BALANCE=25

# Symbol universe
USE_TOP_VOLUME_SYMBOLS=true
TOP_VOLUME_ALLOWLIST=
TOP_VOLUME_MIN_PRICE=0
TOP_VOLUME_MIN_QUOTE_VOLUME=0
# TOP_VOLUME_SYMBOLS_COUNT and TOP_SYMBOLS_LIMIT are hardcoded in config.py (default: 300)
SYMBOL=
SYMBOLS=
EXTRA_SYMBOLS=

# Intervals and data history
MAIN_INTERVAL=15m
CONTEXT_INTERVAL=1h
HISTORY_CANDLES_MAIN=600
HISTORY_CANDLES_CONTEXT=400

# Exchange/execution
LEVERAGE=20
MARGIN_TYPE=ISOLATED
MAX_POSITIONS=2
USE_LIMIT_ONLY=false
LIMIT_OFFSET_PCT=0.0001
LIMIT_TIMEOUT_SEC=6

# Sizing policy
# pct_balance: each position uses RISK_PER_TRADE_PCT of available balance as margin
# fixed_margin: uses FIXED_MARGIN_PER_TRADE_USDT as a flat amount
# risk_based: sizes by risk budget derived from stop distance
SIZING_MODE=pct_balance
FIXED_MARGIN_PER_TRADE_USDT=5
# 1% of available balance per position
RISK_PER_TRADE_PCT=0.01
MARGIN_UTILIZATION=0.95

# Risk limits
COOLDOWN_SEC=180
MAX_CONSECUTIVE_LOSSES=3
RISK_PAUSE_AFTER_LOSSES_SEC=86400
DAILY_DRAWDOWN_LIMIT=0.20
DAILY_DRAWDOWN_LIMIT_USDT=6

# Strategy parameters
EMA_FAST=20
EMA_MID=50
EMA_TREND=200
ATR_PERIOD=14
ATR_AVG_WINDOW=30
VOLUME_AVG_WINDOW=20
RSI_PERIOD=14
RSI_LONG_MIN=48
RSI_LONG_MAX=68
VOLUME_MIN_RATIO=1.05
VOLUME_MAX_RATIO=1.5
PULLBACK_TOLERANCE_ATR=0.8
MIN_EMA_SPREAD_ATR=0.15
MAX_EMA_SPREAD_ATR=1.0
MIN_BODY_RATIO=0.35
RR_TARGET=2.0
MIN_RISK_ATR=0.5
MAX_RISK_ATR=3.0
MIN_SCORE=1.5
# Reject signals when current ATR exceeds this multiple of the rolling ATR average
MAX_ATR_AVG_RATIO=2.5

# Position management
ATR_SL_MULT=1.6
ATR_TP_MULT=1.8
ATR_TRAIL_MULT=1.0
MIN_SL_PCT=0.007
BREAKEVEN_TRIGGER_PCT=0.006
TRAILING_ACTIVATION_PCT=0.010
STOP_ATR_MULT=1.2
TP_RR=1.8
ANTI_LIQ_TRIGGER_R=1.1
# Close position at market after this many candles (0 = disabled)
MAX_HOLD_CANDLES=50

# Signal filtering
# Comma-separated intervals where SELL signals are suppressed (long-only filter)
BLOCK_SELL_ON_INTERVALS=4h

# Scaling controls (currently disabled by monitor runtime)
# DCA on losing positions — only enable after exhaustive backtest
ENABLE_LOSS_SCALING=false
SCALE_LEVEL1_MARGIN_USDT=5
SCALE_LEVEL2_MARGIN_USDT=0
SCALE_LEVEL2_ATR_MULT=0.4

# Logs
LOG_HEARTBEAT_SEC=60
LOG_CANDLE_UPDATES=false
LOG_CANDLE_EVERY_SEC=60

# Operational observability and safety (Stage 3)
# Disabled by default to avoid changing live entry behavior.
ENABLE_OPERATIONAL_KILL_SWITCHES=false
# Thresholds (0 = disabled)
KILL_SWITCH_MAX_CONSECUTIVE_ERRORS=0
KILL_SWITCH_MAX_API_ERRORS=0
KILL_SWITCH_MAX_ORDER_FAILURES=0
KILL_SWITCH_MAX_PROTECTION_FAILURES=0
KILL_SWITCH_MAX_SCHEDULER_IDLE_SEC=0
KILL_SWITCH_PAUSE_ON_ORPHAN_UNRECOVERABLE=false
# Entry suspension duration in seconds once a rule triggers
OPERATIONAL_SUSPEND_SEC=900

# Optional operational alerts (Telegram), rate-limited
ENABLE_OPERATIONAL_ALERTS=false
OPERATIONAL_ALERT_COOLDOWN_SEC=300

# Dashboard/report artifacts
OPS_REPORT_INTERVAL_SEC=60
OPS_RECENT_EVENTS=25
OPS_HOURLY_SUMMARY=true
OPS_DAILY_SUMMARY=true
OPS_STATUS_JSON_PATH=logs/ops_status.json
OPS_SUMMARY_MD_PATH=logs/ops_summary.md
OPS_STATE_JSON_PATH=logs/ops_state.json
